MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=sentinelai

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# Optional: persist Solana keypair across restarts (base64-encoded).
# If not set, a new keypair is generated each startup (needs fresh airdrop).
# The logger prints the value to add here on first run.
SOLANA_PRIVATE_KEY=
